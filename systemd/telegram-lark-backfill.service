[Unit]
Description=Telegram to Lark backfill
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/telegram-lark
Environment=PYTHONIOENCODING=utf-8
ExecStart=/opt/telegram-lark/.venv/bin/python /opt/telegram-lark/scripts/telegram_lark_sync.py --config /opt/telegram-lark/secrets/telegram_lark_sync.config.json backfill --days 1 --batch-size 100
